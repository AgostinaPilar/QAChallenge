{
  "name": "vmetrix-challenge",
  "version": "1.0.0",
  "scripts": {
    "test": "npx playwright test",
    "test:cucumber": "rm -rf allure-results && npx cucumber-js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run test:cucumber && npm run allure:generate && npm run allure:open",
    "test:api": "rm -rf allure-results-api && npx cucumber-js --config backend/cucumber.js",
    "allure:api": "npm run test:api && allure generate allure-results-api --clean -o allure-report-api && allure open allure-report-api"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "allure-cucumberjs": "^3.7.1",
    "allure-js-commons": "^3.7.1",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
